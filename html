
<h2 class="sr-only">Colorful QR Code Generator for packaging</h2>

<div style="max-width:520px; margin:0 auto; padding:1.5rem 0;">

  <p style="font-size:13px; color:var(--color-text-secondary); margin:0 0 6px;">Link daalo:</p>
  <div style="display:flex; gap:8px; margin-bottom:1rem;">
    <input type="text" id="urlInput" placeholder="https://yourlink.com" style="flex:1; font-size:14px;" />
    <button onclick="generateQR()" style="padding:0 18px; font-size:14px; white-space:nowrap; background:#6c47d4; color:white; border:none; border-radius:8px; cursor:pointer;">Generate QR</button>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px; margin-bottom:1rem;">
    <div>
      <p style="font-size:12px; color:var(--color-text-secondary); margin:0 0 4px;">Size</p>
      <select id="sizeSelect" style="font-size:13px; width:100%;">
        <option value="120">Small — Tiny Label</option>
        <option value="160" selected>Medium — Packaging</option>
        <option value="200">Large — Box/Poster</option>
      </select>
    </div>
    <div>
      <p style="font-size:12px; color:var(--color-text-secondary); margin:0 0 4px;">Style</p>
      <select id="styleSelect" style="font-size:13px; width:100%;">
        <option value="scanme" selected>SCAN ME Label</option>
        <option value="border">Border Frame Only</option>
        <option value="plain">Plain QR</option>
      </select>
    </div>
  </div>

  <p style="font-size:12px; color:var(--color-text-secondary); margin:0 0 6px;">QR Color Theme:</p>
  <div style="display:flex; gap:8px; margin-bottom:1.5rem; flex-wrap:wrap;" id="colorPicker">
    <div class="colorBtn active" data-fg="#000000" data-bg="#ffffff" data-label="Classic" style="background:#fff; border:2px solid #6c47d4; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#333;">⚫ Classic</div>
    <div class="colorBtn" data-fg="#1a237e" data-bg="#e8eaf6" data-label="Indigo" style="background:#e8eaf6; border:1.5px solid #3f51b5; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#1a237e;">💙 Indigo</div>
    <div class="colorBtn" data-fg="#1b5e20" data-bg="#e8f5e9" data-label="Green" style="background:#e8f5e9; border:1.5px solid #4caf50; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#1b5e20;">💚 Green</div>
    <div class="colorBtn" data-fg="#b71c1c" data-bg="#ffebee" data-label="Red" style="background:#ffebee; border:1.5px solid #ef5350; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#b71c1c;">❤️ Red</div>
    <div class="colorBtn" data-fg="#4a148c" data-bg="#f3e5f5" data-label="Purple" style="background:#f3e5f5; border:1.5px solid #9c27b0; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#4a148c;">💜 Purple</div>
    <div class="colorBtn" data-fg="#e65100" data-bg="#fff3e0" data-label="Orange" style="background:#fff3e0; border:1.5px solid #ff9800; border-radius:8px; padding:6px 12px; cursor:pointer; font-size:12px; font-weight:500; color:#e65100;">🟠 Orange</div>
  </div>

  <div id="qrOutput" style="display:flex; justify-content:center; align-items:center; min-height:240px; background:var(--color-background-secondary); border-radius:var(--border-radius-lg); border:0.5px solid var(--color-border-tertiary); padding:1.5rem;">
    <p style="color:var(--color-text-secondary); font-size:14px; text-align:center;">Upar link daalo aur Generate dabao 👆</p>
  </div>

  <div id="downloadBtns" style="display:none; margin-top:1rem; gap:8px; justify-content:center;">
    <button onclick="downloadSVG()" style="font-size:13px; padding:8px 20px;"><i class="ti ti-download" aria-hidden="true"></i> SVG Download</button>
    <button onclick="downloadPNG()" style="font-size:13px; padding:8px 20px;"><i class="ti ti-photo" aria-hidden="true"></i> PNG Download</button>
  </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script>
let lastSVG = '';
let selectedFG = '#000000';
let selectedBG = '#ffffff';

document.querySelectorAll('.colorBtn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.colorBtn').forEach(b => b.style.borderWidth = '1.5px');
    btn.style.borderWidth = '3px';
    selectedFG = btn.dataset.fg;
    selectedBG = btn.dataset.bg;
  });
});

function generateQR() {
  const url = document.getElementById('urlInput').value.trim();
  if (!url) { alert('Pehle link daalo!'); return; }
  const size = parseInt(document.getElementById('sizeSelect').value);
  const style = document.getElementById('styleSelect').value;
  const out = document.getElementById('qrOutput');
  out.innerHTML = '<p style="color:var(--color-text-secondary); font-size:13px;">Generating...</p>';

  const temp = document.createElement('div');
  temp.style.cssText = 'position:fixed;left:-9999px;top:-9999px;';
  document.body.appendChild(temp);

  try {
    new QRCode(temp, {
      text: url,
      width: 512,
      height: 512,
      colorDark: selectedFG,
      colorLight: selectedBG,
      correctLevel: QRCode.CorrectLevel.H
    });
  } catch(e) {
    out.innerHTML = '<p style="color:red; font-size:13px;">QR generate nahi hua. Link check karo.</p>';
    temp.remove();
    return;
  }

  setTimeout(() => {
    const canvas = temp.querySelector('canvas');
    if (!canvas) {
      out.innerHTML = '<p style="color:red; font-size:13px;">Error: canvas nahi mila.</p>';
      temp.remove();
      return;
    }

    const imgData = canvas.toDataURL('image/png');
    const pad = style === 'plain' ? 0 : 14;
    const labelH = style === 'scanme' ? 36 : 0;
    const totalW = size + pad * 2;
    const totalH = size + pad * 2 + labelH;
    const r = style !== 'plain' ? 10 : 0;

    let svgContent = '';

    if (style === 'plain') {
      svgContent = `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 ${size} ${size}">
        <image href="${imgData}" x="0" y="0" width="${size}" height="${size}"/>
      </svg>`;
    } else if (style === 'border') {
      svgContent = `<svg xmlns="http://www.w3.org/2000/svg" width="${totalW}" height="${totalH}" viewBox="0 0 ${totalW} ${totalH}">
        <rect x="1" y="1" width="${totalW-2}" height="${totalH-2}" rx="${r}" fill="${selectedBG}" stroke="${selectedFG}" stroke-width="2.5"/>
        <image href="${imgData}" x="${pad}" y="${pad}" width="${size}" height="${size}"/>
      </svg>`;
    } else {
      svgContent = `<svg xmlns="http://www.w3.org/2000/svg" width="${totalW}" height="${totalH}" viewBox="0 0 ${totalW} ${totalH}">
        <rect x="1" y="1" width="${totalW-2}" height="${totalH-2}" rx="${r}" fill="${selectedBG}" stroke="${selectedFG}" stroke-width="2.5"/>
        <image href="${imgData}" x="${pad}" y="${pad}" width="${size}" height="${size}"/>
        <rect x="1" y="${size + pad*2}" width="${totalW-2}" height="${labelH}" rx="0" fill="${selectedFG}"/>
        <rect x="1" y="${totalH - labelH - r}" width="${totalW-2}" height="${r}" fill="${selectedFG}"/>
        <rect x="1" y="${totalH - labelH}" width="${totalW-2}" height="${labelH - 1}" rx="0" ry="0" fill="${selectedFG}"/>
        <path d="M1,${totalH - labelH} L${totalW-1},${totalH - labelH} L${totalW-1},${totalH - r} Q${totalW-1},${totalH-1} ${totalW-r-1},${totalH-1} L${r+1},${totalH-1} Q1,${totalH-1} 1,${totalH-r} Z" fill="${selectedFG}"/>
        <text x="${totalW/2}" y="${size + pad*2 + labelH/2 + 5}" text-anchor="middle" fill="${selectedBG}" font-family="Arial Black, Arial, sans-serif" font-size="13" font-weight="900" letter-spacing="3">SCAN ME</text>
      </svg>`;
    }

    lastSVG = svgContent;
    out.innerHTML = '';

    const wrapper = document.createElement('div');
    wrapper.style.cssText = 'background:white; display:inline-block; padding:10px; border-radius:10px; box-shadow:0 2px 12px rgba(0,0,0,0.12);';
    wrapper.innerHTML = svgContent;
    out.appendChild(wrapper);

    const dl = document.getElementById('downloadBtns');
    dl.style.display = 'flex';
    temp.remove();
  }, 300);
}

function downloadSVG() {
  if (!lastSVG) return;
  const blob = new Blob([lastSVG], {type: 'image/svg+xml'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'qrcode.svg'; a.click();
}

function downloadPNG() {
  if (!lastSVG) return;
  const canvas = document.createElement('canvas'); canvas.width = 600; canvas.height = 600;
  const ctx = canvas.getContext('2d');
  const img = new Image();
  const blob = new Blob([lastSVG], {type: 'image/svg+xml'});
  img.onload = () => {
    ctx.fillStyle = 'white'; ctx.fillRect(0,0,600,600);
    ctx.drawImage(img, 0, 0, 600, 600);
    const a = document.createElement('a'); a.href = canvas.toDataURL('image/png'); a.download = 'qrcode.png'; a.click();
  };
  img.src = URL.createObjectURL(blob);
}
</script>
